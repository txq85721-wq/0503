page {
  background: #f6f7f9;
  color: #1f2933;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 32rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.subtitle {
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.6;
}

.btn {
  background: #16a34a;
  color: #ffffff;
  border-radius: 999rpx;
  margin-top: 24rpx;
}

.input {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 22rpx;
  margin: 16rpx 0;
}

.label {
  font-size: 26rpx;
  color: #475569;
  margin-top: 18rpx;
}
