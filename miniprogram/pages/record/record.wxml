<view class="container">
  <view class="card">
    <view class="title">饮食记录</view>

    <input class="input" placeholder="食物名称" data-field="foodName" bindinput="onInput" value="{{foodName}}" />
    <input class="input" placeholder="热量(kcal)" data-field="calories" bindinput="onInput" value="{{calories}}" />

    <button class="btn" bindtap="addRecord">添加记录</button>
  </view>

  <view class="card">
    <view class="title">今日摄入</view>
    <view>总热量：{{totalCalories}} kcal</view>
  </view>

  <view class="card">
    <view class="title">记录列表</view>
    <view wx:for="{{records}}" wx:key="index">
      {{item.foodName}} - {{item.calories}} kcal
    </view>
  </view>
</view>
