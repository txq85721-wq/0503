<view class="container page-index">

  <view class="hero-card">
    <view class="hero-subtitle">LESSugar</view>
    <view class="title">今日饮食概览</view>
    <view class="hero-subtitle">{{checkinText}} · 连续 {{streak}} 天</view>

    <view class="hero-metric-value">{{todayCalories}} kcal</view>

    <view class="progress-track">
      <view class="progress-fill" style="width: {{progressPercent}}%"></view>
    </view>

    <view class="hero-subtitle">目标 {{targetCalories}} · 剩余 {{remainingCalories}}</view>
  </view>

  <view class="dashboard-grid">
    <view class="metric-card">
      <view class="metric-label">已摄入</view>
      <view class="metric-value">{{todayCalories}}</view>
    </view>

    <view class="metric-card">
      <view class="metric-label">剩余</view>
      <view class="metric-value">{{remainingCalories}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">AI分析</view>
    <view class="tip">{{aiSummary}}</view>
  </view>

  <view class="card">
    <view class="section-title">晚餐建议</view>
    <view class="tip">{{dinnerSuggestion}}</view>
  </view>

  <view class="card">
    <view class="section-title">快捷操作</view>
    <navigator class="btn nav-btn" open-type="switchTab" url="/pages/record/record">记录饮食</navigator>
    <navigator class="btn-secondary nav-btn" open-type="switchTab" url="/pages/recommend/recommend">查看推荐</navigator>
  </view>

</view>
